# Database
# Using PostgreSQL via Neon/Supabase/Render
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# NextAuth Configuration
# Run `openssl rand -base64 32` to generate a secret
NEXTAUTH_SECRET="your-super-secret-nextauth-key"
NEXTAUTH_URL="http://localhost:3000"

# Razorpay Integration (Payments)
# Get these from your Razorpay Dashboard (Test or Live mode)
RAZORPAY_KEY_ID="rzp_test_yourkeyid"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_yourkeyid"

# Resend (Email / OTP Verification)
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="onboarding@resend.dev"

# UPI Payment Details (for direct payment flow)
NEXT_PUBLIC_UPI_ID="yourname@upi"
NEXT_PUBLIC_UPI_PHONE="9876543210"
NEXT_PUBLIC_UPI_NAME="Aluminium House"

# Cloudinary (Image Hosting)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
