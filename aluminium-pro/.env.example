# Database
# Using PostgreSQL via Neon/Supabase/Render
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# NextAuth Configuration
# Run `openssl rand -base64 32` to generate a secret
NEXTAUTH_SECRET="your-super-secret-nextauth-key"
NEXTAUTH_URL="http://localhost:3000"

# Razorpay Integration (Payments)
# Get these from your Razorpay Dashboard (Test or Live mode)
RAZORPAY_KEY_ID="rzp_test_yourkeyid"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_yourkeyid"

# SendGrid (Email Notifications - Optional for Phase 11, prep for future)
SENDGRID_API_KEY="SG.your-sendgrid-api-key"

# Cloudinary (Image Hosting - Optional for future expansion)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
